rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos: only the signed-in user can write/read their own folder.
    match /profiles/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny (keep private by default).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

